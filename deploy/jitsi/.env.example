# Copy to .env next to docker-compose.yml and fill in.

# Public address of the Jitsi server (must match JITSI_DOMAIN in the Django .env)
PUBLIC_URL=https://meet.tabibalhafiz.com

# JWT auth — MUST be identical to JITSI_APP_ID / JITSI_APP_SECRET in the Django .env
JITSI_APP_ID=hafez
JITSI_APP_SECRET=generate-with-openssl-rand-hex-32

# Internal component passwords — generate with: openssl rand -hex 16
JICOFO_AUTH_PASSWORD=change-me
JVB_AUTH_PASSWORD=change-me

# Media port (UDP) — must be open in the firewall
JVB_PORT=10000
# Public IP(s) the videobridge advertises to clients (comma-separated).
# Required when the server is behind NAT; on a VPS use its public IP.
JVB_ADVERTISE_IPS=

# TLS: either terminate directly with Let's Encrypt...
ENABLE_LETSENCRYPT=1
LETSENCRYPT_DOMAIN=meet.tabibalhafiz.com
LETSENCRYPT_EMAIL=admin@tabibalhafiz.com
HTTP_PORT=80
HTTPS_PORT=443
# ...or run behind your own reverse proxy instead:
# DISABLE_HTTPS=1
# HTTP_PORT=8000

TZ=Africa/Algiers
