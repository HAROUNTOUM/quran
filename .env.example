# Django
SECRET_KEY=change-this-to-a-long-random-string
ALLOWED_HOSTS=.example.com,www.example.com
DEBUG=False

# Database (PostgreSQL)
DB_NAME=hafez
DB_USER=hafez
DB_PASSWORD=change-this-password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email (Gmail SMTP with app password)
# SSL on port 465; EMAIL_USE_TLS and EMAIL_USE_SSL are mutually exclusive — set only one to True.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_HOST_USER=a_toum@estin.dz
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
DEFAULT_FROM_EMAIL="الطبيب الحافظ <noreply@tabibalhafiz.com>"

# Jitsi (self-hosted with JWT auth — see deploy/jitsi/README.md)
# JITSI_APP_ID / JITSI_APP_SECRET must match deploy/jitsi/.env on the Jitsi server.
JITSI_DOMAIN=meet.tabibalhafiz.com
JITSI_APP_ID=hafez
JITSI_APP_SECRET=generate-with-openssl-rand-hex-32
JITSI_JWT_TTL=7200

# Sentry (optional)
SENTRY_DSN=
